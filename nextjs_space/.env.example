# Banco de Dados
DATABASE_URL="postgresql://user:password@localhost:5432/lerp_intranet"

# NextAuth
NEXTAUTH_SECRET="gere-uma-chave-aleatoria-segura-aqui-com-openssl-rand-base64-32"
