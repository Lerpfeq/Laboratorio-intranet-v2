# Crie um arquivo .env.local com os valores abaixo durante desenvolvimento

# Banco de Dados (local)
DATABASE_URL="postgresql://postgres:password@localhost:5432/lerp_intranet"

# NextAuth
NEXTAUTH_SECRET="seu-secret-seguro-local"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (copie do Google Cloud Console)
GOOGLE_CLIENT_ID="SEU_CLIENT_ID.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="seu_secret_aqui"

# Ambiente
NODE_ENV="development"
